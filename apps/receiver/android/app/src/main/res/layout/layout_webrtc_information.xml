<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="#8C000000"
    android:padding="5dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:text="------org.webrtc.Logging------"
            android:textColor="@android:color/white"
            android:textSize="10dp"
            tools:ignore="HardcodedText,SpUsage" />

        <TextView
            android:id="@+id/textDecoder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Decoder: "
            android:textColor="@android:color/white"
            android:textSize="10dp"
            tools:ignore="HardcodedText,SpUsage" />

        <TextView
            android:id="@+id/textFPS"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Render fps:"
            android:textColor="@android:color/white"
            android:textSize="10dp"
            tools:ignore="HardcodedText,SpUsage" />

        <TextView
            android:id="@+id/textStateID"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:text="------State machine------"
            android:textColor="@android:color/white"
            android:textSize="10dp"
            tools:ignore="HardcodedText,SpUsage" />

        <TextView
            android:id="@+id/textLastState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last State: Init."
            android:textColor="@android:color/white"
            android:textSize="10dp"
            tools:ignore="HardcodedText,SpUsage" />
    </LinearLayout>
</ScrollView>